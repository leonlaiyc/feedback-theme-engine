# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
build/
dist/
*.egg-info/

# Virtual environments
.venv/
venv/
env/
ENV/

# Notebooks
.ipynb_checkpoints/

# Environment variables and secrets
.env
.env.*
!.env.example
*.pem
*.key
secret.*
secrets.*
*.secret
*.secrets

# Data policy: do not commit raw or real processed datasets
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep

# Large generated artifacts
artifacts/
models/
embeddings/
*.npy
*.npz
*.parquet
*.pkl
*.joblib

# Outputs generated from real data unless explicitly approved
outputs/*
!outputs/.gitkeep

# OS and editor files
.DS_Store
Thumbs.db
.idea/
.vscode/
